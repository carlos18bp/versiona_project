# =============================================================================
# Environment
# =============================================================================
DJANGO_ENV=development
DJANGO_SECRET_KEY=change-me-replace-with-strong-secret-min-50-chars
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_LOG_LEVEL=INFO

# =============================================================================
# CORS / CSRF (comma-separated origins)
# =============================================================================
DJANGO_CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# =============================================================================
# Database — PostgreSQL (native install, docs/plan/07 §2.1)
# =============================================================================
DJANGO_DB_ENGINE=django.db.backends.postgresql
DJANGO_DB_NAME=versiona
DB_USER=versiona
DB_PASSWORD=replace-me
DB_HOST=127.0.0.1
DB_PORT=5432

# =============================================================================
# Redis / Celery (docs/plan/05 §7 — queues: default, engine_light, engine_heavy)
# =============================================================================
REDIS_URL=redis://localhost:6379/1
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1
# 1 = run tasks inline (dev/tests). 0 = require a real celery worker.
CELERY_TASK_ALWAYS_EAGER=1

# =============================================================================
# Object storage — S3/MinIO (leave bucket empty to fall back to local files)
# =============================================================================
AWS_S3_ENDPOINT_URL=http://127.0.0.1:9000
AWS_ACCESS_KEY_ID=versiona-minio
AWS_SECRET_ACCESS_KEY=replace-me
AWS_STORAGE_BUCKET_NAME=versiona-media
MEDIA_SIGNED_URL_TTL_SECONDS=300

# =============================================================================
# JWT
# =============================================================================
DJANGO_JWT_ACCESS_MINUTES=15
DJANGO_JWT_REFRESH_DAYS=7

# =============================================================================
# Email — mailpit in dev (docs/plan/07 §2.1); real SMTP in production
# =============================================================================
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DJANGO_EMAIL_HOST=127.0.0.1
DJANGO_EMAIL_PORT=1025
DJANGO_EMAIL_USE_TLS=false
DJANGO_EMAIL_HOST_USER=
DJANGO_EMAIL_HOST_PASSWORD=
DJANGO_DEFAULT_FROM_EMAIL=versiona@localhost

# =============================================================================
# Google OAuth / reCAPTCHA
# =============================================================================
DJANGO_GOOGLE_CLIENT_ID=
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# =============================================================================
# Frontend
# =============================================================================
FRONTEND_URL=http://localhost:3000

# =============================================================================
# Versiona engine / domain (consumed from It1 on; docs/plan/07 §2)
# =============================================================================
MAX_PDF_SIZE_MB=25
OCR_ENABLED=0
D5_DEFAULT_MODE=auto
D5_OCR_CONFIDENCE_MIN=0.75
# SEAL_SIGNING_KEY_PATH=/etc/versiona/seal_signing_key.pem  (It3)
# WOMPI_PUBLIC_KEY= / WOMPI_PRIVATE_KEY= / WOMPI_EVENTS_SECRET=  (It7, DP-01)

# =============================================================================
# Operations
# =============================================================================
BACKUP_STORAGE_PATH=/var/backups/versiona
ENABLE_SILK=false
